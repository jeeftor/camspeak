# camspeak environment variables
# All values are optional — defaults are sensible for local dev.
# In Docker, set these in your docker-compose env section.

# Data directory (holds camspeak.db + library/ folder)
# Default: ./data (local) or /config (Docker)
CAMSPEAK_DATA_DIR=/config

# Server port
CAMSPEAK_PORT=8585

# Frigate NVR URL — for auto-discovery of cameras
# When set and no cameras are in the DB, camspeak will discover them on startup
CAMSPEAK_FRIGATE_URL=http://frigate:5000

# TTS endpoint (OpenAI-compatible /v1/audio/speech)
# These override the active TTS preset in the database
CAMSPEAK_TTS_URL=http://tts:8080/v1/audio/speech
CAMSPEAK_TTS_MODEL=kokoro
CAMSPEAK_TTS_VOICE=af_sky
# CAMSPEAK_TTS_API_KEY=  # only needed for cloud TTS providers

# MQTT broker (for Frigate event-triggered auto-speak)
# Leave empty to disable MQTT
CAMSPEAK_MQTT_BROKER=tcp://mqtt:1883
CAMSPEAK_MQTT_USER=
CAMSPEAK_MQTT_PASS=

# Per-camera credential overrides (optional)
# Format: CAM_<CAMERA_NAME>_IP, CAM_<CAMERA_NAME>_USER, CAM_<CAMERA_NAME>_PASS
# Camera name is uppercased with hyphens replaced by underscores
# Example:
# CAM_BACKYARD_IP=10.0.0.1
# CAM_BACKYARD_USER=admin
# CAM_BACKYARD_PASS=your-password
